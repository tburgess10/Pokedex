<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= type.displayName %> Type — Burgédex</title>
  <script>try{var t=localStorage.getItem('burgedex-theme');if(t)document.documentElement.setAttribute('data-theme',t)}catch(e){}</script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="type-page">
  <nav class="entry-nav">
    <div class="entry-nav__links">
      <a href="/">← Home</a>
      <a href="/pokedex">Pokédex</a>
      <a href="/about">About</a>
    </div>
    <span class="entry-nav__brand">Burgédex</span>
    <div class="entry-nav__search">
      <form action="/pokemon" method="GET">
        <input
          id="pb-search-input"
          class="nav-search-input"
          type="text"
          name="q"
          placeholder="Search Pokémon..."
          autocomplete="off"
        />
      </form>
      <ul class="pb-suggestions" id="pb-suggestions" hidden></ul>
    </div>
  </nav>

  <main class="type-main">

    <!-- Hero -->
    <div class="type-hero-card">
      <span class="type-badge type-<%= type.name %> type-badge--hero"><%= type.displayName %></span>
      <p class="type-counts">
        <span><%= type.pokemon.length %> Pokémon</span>
        <span class="type-counts__sep">·</span>
        <span><%= type.moves.length %> moves</span>
      </p>
    </div>

    <!-- Matchup cards -->
    <div class="type-matchup-row">

      <div class="type-matchup-card">
        <h2 class="type-matchup-title">Offense</h2>
        <p class="type-matchup-sub">When a <strong><%= type.displayName %></strong>-type move hits…</p>

        <% if (type.offense.superEffective.length) { %>
        <div class="type-matchup-group">
          <span class="type-matchup-mult type-matchup-mult--2x">2×</span>
          <div class="type-matchup-badges">
            <% type.offense.superEffective.forEach(t => { %>
              <a class="type-badge type-<%= t %>" href="/types/<%= t %>"><%= t %></a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <% if (type.offense.notVeryEffective.length) { %>
        <div class="type-matchup-group">
          <span class="type-matchup-mult type-matchup-mult--half">½×</span>
          <div class="type-matchup-badges">
            <% type.offense.notVeryEffective.forEach(t => { %>
              <a class="type-badge type-<%= t %>" href="/types/<%= t %>"><%= t %></a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <% if (type.offense.noEffect.length) { %>
        <div class="type-matchup-group">
          <span class="type-matchup-mult type-matchup-mult--0x">0×</span>
          <div class="type-matchup-badges">
            <% type.offense.noEffect.forEach(t => { %>
              <a class="type-badge type-<%= t %>" href="/types/<%= t %>"><%= t %></a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <% if (!type.offense.superEffective.length && !type.offense.notVeryEffective.length && !type.offense.noEffect.length) { %>
          <p class="type-matchup-none">Neutral against all types.</p>
        <% } %>
      </div>

      <div class="type-matchup-card">
        <h2 class="type-matchup-title">Defense</h2>
        <p class="type-matchup-sub">When hit by a <strong><%= type.displayName %></strong>-type Pokémon…</p>

        <% if (type.defense.weakTo.length) { %>
        <div class="type-matchup-group">
          <span class="type-matchup-mult type-matchup-mult--2x">2×</span>
          <div class="type-matchup-badges">
            <% type.defense.weakTo.forEach(t => { %>
              <a class="type-badge type-<%= t %>" href="/types/<%= t %>"><%= t %></a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <% if (type.defense.resists.length) { %>
        <div class="type-matchup-group">
          <span class="type-matchup-mult type-matchup-mult--half">½×</span>
          <div class="type-matchup-badges">
            <% type.defense.resists.forEach(t => { %>
              <a class="type-badge type-<%= t %>" href="/types/<%= t %>"><%= t %></a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <% if (type.defense.immuneTo.length) { %>
        <div class="type-matchup-group">
          <span class="type-matchup-mult type-matchup-mult--0x">0×</span>
          <div class="type-matchup-badges">
            <% type.defense.immuneTo.forEach(t => { %>
              <a class="type-badge type-<%= t %>" href="/types/<%= t %>"><%= t %></a>
            <% }); %>
          </div>
        </div>
        <% } %>

        <% if (!type.defense.weakTo.length && !type.defense.resists.length && !type.defense.immuneTo.length) { %>
          <p class="type-matchup-none">Neutral against all types.</p>
        <% } %>
      </div>

    </div>

    <!-- Pokémon -->
    <% if (type.pokemon.length > 0) { %>
    <section class="ability-pokemon-section">
      <h2 class="ability-section-heading">
        Pokémon
        <span class="ability-pokemon-count"><%= type.pokemon.length %></span>
      </h2>
      <div class="dex-grid">
        <% type.pokemon.forEach(p => { %>
          <a class="dex-card" href="/pokemon/<%= p.name %>">
            <img class="dex-sprite" src="<%= p.sprite %>" alt="<%= p.displayName %>" loading="lazy" />
            <span class="dex-number">#<%= String(p.id).padStart(4, '0') %></span>
            <span class="dex-name"><%= p.displayName %></span>
          </a>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- Moves -->
    <% if (type.moves.length > 0) { %>
    <section class="ability-pokemon-section type-moves-section">
      <h2 class="ability-section-heading">
        Moves
        <span class="ability-pokemon-count"><%= type.moves.length %></span>
      </h2>
      <div class="type-moves-list">
        <% type.moves.forEach(m => { %>
          <a class="type-move-chip" href="/moves/<%= m.name %>"><%= m.displayName %></a>
        <% }); %>
      </div>
    </section>
    <% } %>

  </main>

  <footer>
    <p>&copy; <%= new Date().getFullYear() %> Burgédex</p>
  </footer>
  <script src="/js/main.js"></script>
</body>
</html>
