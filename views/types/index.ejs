<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Types — Burgédex</title>
  <script>try{var t=localStorage.getItem('burgedex-theme');if(t)document.documentElement.setAttribute('data-theme',t)}catch(e){}</script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="entry-page">
  <nav class="entry-nav">
    <div class="entry-nav__links">
      <a href="/">← Home</a>
      <a href="/pokedex">Pokédex</a>
      <a href="/moves">Moves</a>
      <a href="/about">About</a>
    </div>
    <span class="entry-nav__brand">Burgédex</span>
    <div class="entry-nav__search">
      <form action="/pokemon" method="GET">
        <input
          id="pb-search-input"
          class="nav-search-input"
          type="text"
          name="q"
          placeholder="Search Pokémon..."
          autocomplete="off"
        />
      </form>
      <ul class="pb-suggestions" id="pb-suggestions" hidden></ul>
    </div>
  </nav>

  <main class="dex-main">
    <div class="dex-header">
      <h1 class="dex-title">Types</h1>
    </div>
    <div class="types-index-grid">
      <% types.forEach(type => { %>
        <a class="types-index-card type-<%= type %>" href="/types/<%= type %>">
          <%= type %>
        </a>
      <% }); %>
    </div>
  </main>

  <script src="/js/main.js"></script>
</body>
</html>
