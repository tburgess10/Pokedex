<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Moves — Burgédex</title>
  <script>try{var t=localStorage.getItem('burgedex-theme');if(t)document.documentElement.setAttribute('data-theme',t)}catch(e){}</script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="entry-page">
  <nav class="entry-nav">
    <div class="entry-nav__links">
      <a href="/">← Home</a>
      <a href="/pokedex" class="<%= currentSection === 'pokedex' ? 'nav-link--active' : '' %>">Pokédex</a>
      <a href="/types"   class="<%= currentSection === 'types'   ? 'nav-link--active' : '' %>">Types</a>
      <a href="/moves"   class="<%= currentSection === 'moves'   ? 'nav-link--active' : '' %>">Moves</a>
      <a href="/about"   class="<%= currentSection === 'about'   ? 'nav-link--active' : '' %>">About</a>
    </div>
    <span class="entry-nav__brand">Burgédex</span>
    <div class="entry-nav__search">
      <form action="/pokemon" method="GET">
        <input
          id="pb-search-input"
          class="nav-search-input"
          type="text"
          name="q"
          placeholder="Search Pokémon..."
          autocomplete="off"
        />
      </form>
      <ul class="pb-suggestions" id="pb-suggestions" hidden></ul>
    </div>
  </nav>

  <main class="dex-main">
    <div class="dex-header">
      <h1 class="dex-title">Moves</h1>
      <input
        id="moves-index-filter"
        class="dex-filter"
        type="text"
        placeholder="Filter by name…"
        autocomplete="off"
      />
    </div>
    <div class="moves-index-grid" id="moves-index-grid">
      <% moves.forEach(m => { %>
        <a class="moves-index-card" href="/moves/<%= m.name %>" data-name="<%= m.name %>">
          <%= m.displayName %>
        </a>
      <% }); %>
    </div>
    <p class="dex-empty" id="moves-index-empty" hidden>No moves match that name.</p>
  </main>

  <script src="/js/main.js"></script>
</body>
</html>
