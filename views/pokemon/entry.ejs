<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pokemon.capName %> — Burgédex</title>
  <script>try{var t=localStorage.getItem('burgedex-theme');if(t)document.documentElement.setAttribute('data-theme',t)}catch(e){}</script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="entry-page">
  <nav class="entry-nav">
    <div class="entry-nav__links">
      <a href="/">← Home</a>
      <a href="/pokedex">Pokédex</a>
      <a href="/about">About</a>
    </div>

    <div class="entry-nav__pagination">
      <% if (pokemon.prevId) { %>
        <a class="nav-pgbtn" id="nav-prev" href="/pokemon/<%= pokemon.prevId %>">&lsaquo; #<%= String(pokemon.prevId).padStart(4,'0') %></a>
      <% } else { %>
        <span class="nav-pgbtn nav-pgbtn--disabled">&lsaquo;</span>
      <% } %>
      <span class="entry-nav__brand">Burgédex</span>
      <% if (pokemon.nextId) { %>
        <a class="nav-pgbtn" id="nav-next" href="/pokemon/<%= pokemon.nextId %>">#<%= String(pokemon.nextId).padStart(4,'0') %> &rsaquo;</a>
      <% } else { %>
        <span class="nav-pgbtn nav-pgbtn--disabled">&rsaquo;</span>
      <% } %>
    </div>

    <div class="entry-nav__search">
      <form action="/pokemon" method="GET">
        <input
          id="pb-search-input"
          class="nav-search-input"
          type="text"
          name="q"
          placeholder="Search Pokémon..."
          autocomplete="off"
        />
      </form>
      <ul class="pb-suggestions" id="pb-suggestions" hidden></ul>
    </div>
  </nav>

  <%
    const statLabels = {
      'hp':              'HP',
      'attack':          'Attack',
      'defense':         'Defense',
      'special-attack':  'Sp. Atk',
      'special-defense': 'Sp. Def',
      'speed':           'Speed'
    };

    function statColor(v) {
      if (v < 60)  return '#E74C3C';
      if (v < 90)  return '#F39C12';
      if (v < 120) return '#2ECC71';
      return '#3498DB';
    }

    const total        = pokemon.stats.reduce((s, x) => s + x.base_stat, 0);
    const shinyArtwork = pokemon.sprites.other['official-artwork'].front_shiny;
  %>

  <main class="entry-main">
    <div class="entry-card">

      <!-- Left: artwork + sprite -->
      <div class="entry-art-col">
        <div class="entry-artwork-box">
          <img
            id="entry-artwork"
            class="entry-artwork"
            src="<%= pokemon.sprites.other['official-artwork'].front_default %>"
            data-normal="<%= pokemon.sprites.other['official-artwork'].front_default %>"
            data-shiny="<%= shinyArtwork %>"
            alt="<%= pokemon.capName %> official artwork"
          />
        </div>
        <div class="entry-sprite-row">
          <img
            id="entry-sprite"
            class="entry-sprite"
            src="<%= pokemon.sprites.front_default %>"
            data-normal="<%= pokemon.sprites.front_default %>"
            data-shiny="<%= pokemon.sprites.front_shiny %>"
            alt="<%= pokemon.capName %> sprite"
          />
          <div class="entry-sprite-btns">
            <button class="shiny-btn" id="shiny-btn">✦ Shiny</button>
            <% if (pokemon.cries && pokemon.cries.latest) { %>
              <button class="cry-btn" id="cry-btn" data-cry="<%= pokemon.cries.latest %>">♪ Cry</button>
            <% } %>
          </div>
        </div>
        <% if (pokemon.flavorText) { %>
        <p class="entry-flavor">
          "<%= pokemon.flavorText %>"
          <span class="entry-flavor-game"><%= pokemon.flavorGame %></span>
        </p>
        <% } %>
      </div>

      <!-- Right: info -->
      <div class="entry-info-col">

        <div class="entry-info-top">

          <div class="entry-header">
            <span class="entry-number">#<%= String(pokemon.id).padStart(4, '0') %></span>
            <h1 class="entry-name"><%= pokemon.capName %></h1>
            <div class="entry-types">
              <% pokemon.types.forEach(t => { %>
                <a class="type-badge type-<%= t.type.name %>" href="/types/<%= t.type.name %>"><%= t.type.name %></a>
              <% }); %>
            </div>
          </div>

          <%
            const tcGroups = { 4: [], 2: [], 0.5: [], 0.25: [], 0: [] };
            Object.entries(pokemon.typeEffectiveness).forEach(([type, mult]) => {
              if (tcGroups[mult] !== undefined) tcGroups[mult].push(type);
            });
            const tcRows = [
              { mult: 4,    label: '4×',  cls: 'tc-x4'   },
              { mult: 2,    label: '2×',  cls: 'tc-x2'   },
              { mult: 0.5,  label: '½×',  cls: 'tc-half' },
              { mult: 0.25, label: '¼×',  cls: 'tc-qtr'  },
              { mult: 0,    label: '0×',  cls: 'tc-zero' },
            ];
          %>
          <div class="type-chart">
            <h2 class="entry-section-title">Type Matchups</h2>
            <div id="tc-body">
              <% tcRows.forEach(function(row) { %>
                <% if (tcGroups[row.mult] && tcGroups[row.mult].length > 0) { %>
                <div class="tc-row">
                  <span class="tc-mult <%= row.cls %>"><%= row.label %></span>
                  <div class="tc-badges">
                    <% tcGroups[row.mult].forEach(function(t) { %>
                      <a class="type-badge type-<%= t %>" href="/types/<%= t %>"><%= t %></a>
                    <% }); %>
                  </div>
                </div>
                <% } %>
              <% }); %>
            </div>
          </div>

        </div>

        <div class="entry-physical">
          <div class="phys-box">
            <span class="phys-label">Height</span>
            <span class="phys-value" id="phys-height"><%= (pokemon.height / 10).toFixed(1) %> m</span>
          </div>
          <div class="phys-box">
            <span class="phys-label">Weight</span>
            <span class="phys-value" id="phys-weight"><%= (pokemon.weight / 10).toFixed(1) %> kg</span>
          </div>
          <div class="phys-box">
            <span class="phys-label">Base XP</span>
            <span class="phys-value" id="phys-base-exp"><%= pokemon.base_experience %></span>
          </div>
        </div>

        <div class="entry-abilities">
          <h2 class="entry-section-title">Abilities</h2>
          <div class="ability-cards" id="ability-cards">
            <% pokemon.abilityDetails.forEach(a => { %>
              <div class="ability-card <%= a.isHidden ? 'ability-card--hidden' : '' %>">
                <div class="ability-card__header">
                  <a class="ability-card__name" href="/abilities/<%= a.name %>">
                    <%= a.name.split('-').map(w => w[0].toUpperCase() + w.slice(1)).join(' ') %>
                  </a>
                  <% if (a.isHidden) { %>
                    <span class="ability-card__badge">Hidden</span>
                  <% } %>
                </div>
                <% if (a.shortEffect) { %>
                  <p class="ability-card__desc"><%= a.shortEffect %></p>
                <% } %>
              </div>
            <% }); %>
          </div>
        </div>

        <div class="entry-stats">
          <h2 class="entry-section-title">Base Stats</h2>
          <div id="stats-body">
            <% pokemon.stats.forEach(s => { %>
              <div class="stat-row">
                <span class="stat-name"><%= statLabels[s.stat.name] || s.stat.name %></span>
                <span class="stat-num"><%= s.base_stat %></span>
                <div class="stat-track">
                  <div class="stat-bar <%= s.base_stat > 150 ? 'stat-bar--overflow' : '' %>" style="--w:<%= Math.min(100, Math.round(s.base_stat / 150 * 100)) %>%;--c:<%= statColor(s.base_stat) %>"></div>
                </div>
              </div>
            <% }); %>
            <div class="stat-row stat-total-row">
              <span class="stat-name">Total</span>
              <span class="stat-num total-num"><%= total %></span>
              <div class="stat-track">
                <div class="stat-bar <%= total > 720 ? 'stat-bar--overflow' : '' %>" style="--w:<%= Math.min(100, Math.round(total / 720 * 100)) %>%;--c:var(--accent)"></div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
    <% if (pokemon.forms && pokemon.forms.length > 0) { %>
    <%
      const speciesBase     = pokemon.speciesName || pokemon.name;
      const isDefaultForm   = pokemon.name === speciesBase;
      const currentFormLabel = isDefaultForm
        ? 'Base'
        : pokemon.name.slice(speciesBase.length + 1).split('-').map(w => w[0].toUpperCase() + w.slice(1)).join(' ');
    %>
    <div class="entry-forms">
      <h2 class="entry-forms-title">Other Forms</h2>
      <div class="forms-grid" id="forms-grid">

        <!-- Current form — active by default -->
        <div class="form-card form-card--active"
             data-artwork="<%= pokemon.sprites.other['official-artwork'].front_default %>"
             data-artwork-shiny="<%= shinyArtwork || '' %>"
             data-sprite="<%= pokemon.sprites.front_default %>"
             data-sprite-shiny="<%= pokemon.sprites.front_shiny || '' %>"
             data-types="<%= pokemon.types.map(t => t.type.name).join(',') %>"
             data-effectiveness='<%= JSON.stringify(pokemon.typeEffectiveness) %>'
             data-stats='<%= JSON.stringify(pokemon.stats) %>'
             data-abilities='<%= JSON.stringify(pokemon.abilityDetails) %>'
             data-height="<%= pokemon.height %>"
             data-weight="<%= pokemon.weight %>"
             data-base-exp="<%= pokemon.base_experience %>"
             data-display-name="<%= pokemon.name.split('-').map(w => w[0].toUpperCase() + w.slice(1)).join(' ') %>">
          <img class="form-artwork"
               src="<%= pokemon.sprites.other['official-artwork'].front_default %>"
               alt="Base" />
          <span class="form-name"><%= currentFormLabel %></span>
          <div class="form-types">
            <% pokemon.types.forEach(t => { %>
              <a class="type-badge type-<%= t.type.name %>" href="/types/<%= t.type.name %>"><%= t.type.name %></a>
            <% }); %>
          </div>
        </div>

        <% pokemon.forms.forEach(f => { %>
          <%
            const rawLabel = f.name.startsWith(speciesBase + '-')
              ? f.name.slice(speciesBase.length + 1)
              : f.name === speciesBase ? 'Base' : f.name;
            const formLabel = rawLabel.split('-').map(w => w[0].toUpperCase() + w.slice(1)).join(' ');
            const typeStr   = f.types.map(t => t.type.name).join(',');
          %>
          <div class="form-card"
               data-artwork="<%= f.artwork || '' %>"
               data-artwork-shiny="<%= f.artworkShiny || '' %>"
               data-sprite="<%= f.sprite || '' %>"
               data-sprite-shiny="<%= f.spriteShiny || '' %>"
               data-types="<%= typeStr %>"
               data-effectiveness='<%= JSON.stringify(f.typeEffectiveness) %>'
               data-stats='<%= JSON.stringify(f.stats) %>'
               data-abilities='<%= JSON.stringify(f.abilityDetails) %>'
               data-height="<%= f.height %>"
               data-weight="<%= f.weight %>"
               data-base-exp="<%= f.baseExperience %>"
               data-display-name="<%= f.name.split('-').map(w => w[0].toUpperCase() + w.slice(1)).join(' ') %>">
            <% if (f.artwork) { %>
              <img class="form-artwork" src="<%= f.artwork %>" alt="<%= formLabel %>" />
            <% } %>
            <span class="form-name"><%= formLabel %></span>
            <div class="form-types">
              <% f.types.forEach(t => { %>
                <a class="type-badge type-<%= t.type.name %>" href="/types/<%= t.type.name %>"><%= t.type.name %></a>
              <% }); %>
            </div>
          </div>
        <% }); %>

      </div>
    </div>
    <% } %>

    <% if (pokemon.evolutionStages && pokemon.evolutionStages.length > 1) { %>
    <div class="entry-evolutions">
      <h2 class="entry-forms-title">Evolution Line</h2>
      <div class="evo-chain">
        <% pokemon.evolutionStages.forEach(function(stage, si) { %>
          <% if (si > 0) { %><div class="evo-arrow">→</div><% } %>
          <div class="evo-stage <%= stage.length > 1 ? 'evo-stage--branched' : '' %>">
            <% stage.forEach(function(mon) { %>
              <%
                const isCurrent = mon.id === pokemon.speciesId;
                const evoLabel  = mon.name.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
              %>
              <a class="evo-card <%= isCurrent ? 'evo-card--current' : '' %>"
                 href="/pokemon/<%= mon.name %>">
                <% if (mon.trigger) { %>
                  <span class="evo-trigger"><%= mon.trigger %></span>
                <% } %>
                <img class="evo-sprite"
                     src="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/<%= mon.id %>.png"
                     alt="<%= evoLabel %>" />
                <span class="evo-name"><%= evoLabel %></span>
              </a>
            <% }); %>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (pokemon.movesTable && Object.keys(pokemon.movesTable).length > 0) { %>
    <%
      const METHOD_LABELS = { 'level-up': 'Level Up', 'machine': 'TM', 'egg': 'Egg', 'tutor': 'Tutor' };
      const moveMethods   = Object.keys(pokemon.movesTable);
    %>
    <div class="entry-moves">
      <div class="entry-moves__header">
        <h2 class="entry-forms-title">Moves</h2>
        <% if (pokemon.availableVersionGroups && pokemon.availableVersionGroups.length > 0) { %>
          <select id="moves-vg-select" class="moves-vg-select" data-pokemon="<%= pokemon.name %>">
            <% pokemon.availableVersionGroups.forEach(function(vg) { %>
              <option value="<%= vg.id %>" <%= vg.id === pokemon.movesVersionGroupId ? 'selected' : '' %>>
                <%= vg.label %>
              </option>
            <% }); %>
          </select>
        <% } %>
      </div>

      <div class="moves-tabs-row">
        <div class="moves-tabs">
          <% moveMethods.forEach(function(method, i) { %>
            <button class="moves-tab-btn <%= i === 0 ? 'moves-tab-btn--active' : '' %>"
                    data-method="<%= method %>">
              <%= METHOD_LABELS[method] || method %>
            </button>
          <% }); %>
        </div>
        <input
          type="text"
          id="moves-search"
          class="moves-search"
          placeholder="Search moves…"
          autocomplete="off"
        />
      </div>

      <% moveMethods.forEach(function(method, i) { %>
        <div class="moves-panel <%= i > 0 ? 'moves-panel--hidden' : '' %>" data-method="<%= method %>">
          <div class="moves-table-wrap">
            <table class="moves-table">
              <thead>
                <tr>
                  <% if (method === 'level-up') { %><th class="moves-th moves-th--lv">Lv</th><% } %>
                  <th class="moves-th moves-th--name">Move</th>
                  <th class="moves-th">Type</th>
                  <th class="moves-th">Cat</th>
                  <th class="moves-th moves-th--num">Pwr</th>
                  <th class="moves-th moves-th--num">Acc</th>
                  <th class="moves-th moves-th--num">PP</th>
                </tr>
              </thead>
              <tbody>
                <% pokemon.movesTable[method].forEach(function(m) { %>
                  <tr class="moves-row">
                    <% if (method === 'level-up') { %>
                      <td class="moves-td moves-td--lv"><%= m.level || '—' %></td>
                    <% } %>
                    <td class="moves-td moves-td--name"><a href="/moves/<%= m.name %>" class="move-link"><%= m.displayName %></a></td>
                    <td class="moves-td">
                      <% if (m.type) { %>
                        <span class="type-badge type-<%= m.type %>"><%= m.type %></span>
                      <% } else { %>—<% } %>
                    </td>
                    <td class="moves-td">
                      <% if (m.damageClass) { %>
                        <span class="move-cat move-cat--<%= m.damageClass %>">
                          <%= m.damageClass === 'physical' ? 'Phys' : m.damageClass === 'special' ? 'Spec' : 'Stat' %>
                        </span>
                      <% } else { %>—<% } %>
                    </td>
                    <td class="moves-td moves-td--num"><%= m.power    !== null ? m.power    : '—' %></td>
                    <td class="moves-td moves-td--num"><%= m.accuracy !== null ? m.accuracy : '—' %></td>
                    <td class="moves-td moves-td--num"><%= m.pp       !== null ? m.pp       : '—' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% }); %>
    </div>
    <% } %>

  </main>

  <footer>
    <p>&copy; <%= new Date().getFullYear() %> Burgédex</p>
  </footer>
  <script src="/js/main.js"></script>
</body>
</html>
