<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Not Found — Burgédex</title>
  <script>try{var t=localStorage.getItem('burgedex-theme');if(t)document.documentElement.setAttribute('data-theme',t)}catch(e){}</script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="entry-page">
  <nav class="entry-nav">
    <div class="entry-nav__links">
      <a href="/">← Home</a>
      <a href="/pokedex" class="<%= currentSection === 'pokedex' ? 'nav-link--active' : '' %>">Pokédex</a>
      <a href="/types"   class="<%= currentSection === 'types'   ? 'nav-link--active' : '' %>">Types</a>
      <a href="/moves"   class="<%= currentSection === 'moves'   ? 'nav-link--active' : '' %>">Moves</a>
      <a href="/about"   class="<%= currentSection === 'about'   ? 'nav-link--active' : '' %>">About</a>
    </div>
    <span class="entry-nav__brand">Burgédex</span>
    <div class="entry-nav__search">
      <form action="/pokemon" method="GET">
        <input
          id="pb-search-input"
          class="nav-search-input"
          type="text"
          name="q"
          placeholder="Search Pokémon..."
          autocomplete="off"
        />
      </form>
      <ul class="pb-suggestions" id="pb-suggestions" hidden></ul>
    </div>
  </nav>
  <main style="max-width:600px;margin:3rem auto;padding:0 1.5rem;text-align:center;">
    <h1>No Pokémon found</h1>
    <p>"<strong><%= query %></strong>" didn't match any Pokémon. Try a name like <em>pikachu</em> or a number like <em>25</em>.</p>
    <a href="/">← Back to search</a>
  </main>
  <footer><p>&copy; <%= new Date().getFullYear() %> Burgédex</p></footer>
  <script src="/js/main.js"></script>
</body>
</html>
