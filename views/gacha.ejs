<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stat Roll — Burgédex</title>
  <script>try{var t=localStorage.getItem('burgedex-theme');if(t)document.documentElement.setAttribute('data-theme',t)}catch(e){}</script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="entry-page">
  <nav class="entry-nav">
    <div class="entry-nav__links">
      <a href="/">← Home</a>
      <a href="/pokedex" class="<%= currentSection === 'pokedex' ? 'nav-link--active' : '' %>">Pokédex</a>
      <a href="/types"   class="<%= currentSection === 'types'   ? 'nav-link--active' : '' %>">Types</a>
      <a href="/moves"   class="<%= currentSection === 'moves'   ? 'nav-link--active' : '' %>">Moves</a>
      <a href="/roll"    class="<%= currentSection === 'roll'    ? 'nav-link--active' : '' %>">Roll</a>
    </div>
    <span class="entry-nav__brand">Burgédex</span>
    <div class="entry-nav__search">
      <form action="/pokemon" method="GET">
        <input
          id="pb-search-input"
          class="nav-search-input"
          type="text"
          name="q"
          placeholder="Search Pokémon..."
          autocomplete="off"
        />
      </form>
      <ul class="pb-suggestions" id="pb-suggestions" hidden></ul>
    </div>
  </nav>

  <main class="gacha-main">

    <!-- ── Game panel ── -->
    <div id="gacha-game">

      <div class="gacha-header">
        <h1 class="gacha-title">Stat Roll</h1>
        <p class="gacha-subtitle">Six random Pokémon, six stats — pick one each round to build your team.</p>
        <span class="gacha-best-score" id="gacha-best-score" style="display:none"></span>
      </div>

      <div class="gacha-round-bar">
        <span class="gacha-round-label" id="gacha-round-label">Round 1 of 6</span>
        <div class="gacha-dots">
          <span class="gacha-dot" data-round="1"></span>
          <span class="gacha-dot" data-round="2"></span>
          <span class="gacha-dot" data-round="3"></span>
          <span class="gacha-dot" data-round="4"></span>
          <span class="gacha-dot" data-round="5"></span>
          <span class="gacha-dot" data-round="6"></span>
        </div>
      </div>

      <div class="gacha-round-hint" id="gacha-round-hint">Loading…</div>

      <%
        const statKeys   = ['hp','attack','defense','special-attack','special-defense','speed'];
        const statLabels = {
          'hp':'HP','attack':'Attack','defense':'Defense',
          'special-attack':'Sp. Atk','special-defense':'Sp. Def','speed':'Speed'
        };
      %>
      <div class="gacha-grid">
        <% statKeys.forEach(function(stat) { %>
        <div class="gacha-card gacha-card--loading" data-stat="<%= stat %>">
          <span class="gacha-stat-label"><%= statLabels[stat] %></span>
          <div class="gacha-card__art-wrap">
            <img class="gacha-card__sprite" src="" alt="" />
            <div class="gacha-card__loading-ring"></div>
          </div>
          <span class="gacha-card__name">—</span>
          <span class="gacha-card__value gacha-card__value--hidden">—</span>
          <div class="gacha-card__chosen-overlay">✓</div>
          <div class="gacha-card__autoclaim-overlay">Claiming…</div>
        </div>
        <% }); %>
      </div>

      <div class="gacha-chosen-panel" id="gacha-chosen-panel" hidden>
        <div class="gacha-chosen-label">Your stats so far</div>
        <div class="gacha-chosen-row" id="gacha-chosen-row"></div>
        <div class="gacha-partial-total" id="gacha-partial-total"></div>
      </div>

    </div><!-- /gacha-game -->

    <!-- ── Results panel ── -->
    <div id="gacha-results" hidden>

      <div class="gacha-results-card">
        <h2 class="gacha-results-title">Your Pokémon</h2>

        <div class="gacha-results-stats" id="gacha-results-stats"></div>

        <div class="gacha-results-divider"></div>

        <div class="gacha-total-wrap">
          <span class="gacha-total-label">Total BST</span>
          <span class="gacha-total-value" id="gacha-total-value">—</span>
        </div>

        <div class="gacha-percentile-wrap">
          <div class="gacha-percentile-badge" id="gacha-percentile-badge">Calculating…</div>
          <div class="gacha-percentile-sub">based on 1,025 Pokémon</div>
        </div>

        <div class="gacha-highscore-wrap">
          <span class="gacha-highscore-label">Personal Best</span>
          <span class="gacha-highscore-value" id="gacha-highscore-value">—</span>
          <span class="gacha-newrecord" id="gacha-newrecord" hidden>New Record!</span>
        </div>

        <button class="gacha-retry-btn" id="gacha-retry-btn">Try Again</button>
      </div>

    </div><!-- /gacha-results -->

  </main>

  <footer><p>&copy; <%= new Date().getFullYear() %> Burgédex</p></footer>
  <script src="/js/main.js"></script>
  <script src="/js/gacha.js"></script>
</body>
</html>
